#!/bin/bash
# depends on vlc, acpi, amixer (pulseaudio!)

audiofile="alarms/horn-signal-quotalarmquot.mp3"
above=80
sleeptime=10

# the direcory in which the script is
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
audiopath=$SCRIPT_DIR/$audiofile

# a continuous loop is running
while :; do
	# every ten seconds
    sleep $sleeptime
	# remove the previous battery log
	rm /var/tmp/battlog.txt
	# write battery state to log
	acpi -b > /var/tmp/battlog.txt
	# if the battery is currently charging (not charging)
#	if [ $(grep -c "Charging"  /var/tmp/battlog.txt) -eq 1 ];
	if [ $(grep -c " charging"  /var/tmp/battlog.txt) -eq 1 ]; # dev case: "Not charging"
	then
		# grab only the line that describes the charging battery
#		battery=$(grep "Charging" /var/tmp/battlog.txt)
		battery=$(grep " charging" /var/tmp/battlog.txt) # dev case: "Not charging"
		# get the percentage
		charged=$(echo $battery | grep -o "[0-9][0-9]\%")
		# get a vaule
		percentage=$(echo ${charged:0:-1})
		# if the precentage is above 80%
		if [ $percentage -ge $above ];
		then
			# if muted
			muted=0
			amix=$(amixer -D pulse sget Master)
			if [ $(echo $amix | grep -c "\[off\]") -ge 0 ];
			then
				# indicate that the system was muted
				muted=1
				# unmute
				amixer -D pulse sset Master on > /dev/null
			fi
			# run the fucking alarm!
			vlc $audiopath --loop --volume-step 256 > /dev/null
			# mute back
			if [ $muted -ge 0 ];
			then
				amixer -D pulse sset Master off /dev/null
			fi
		fi
	fi
done
